# Copy to .env and adjust. The server reads these directly from the environment.

# HTTP listen address.
PLATFORM_HTTP_ADDR=:8080

# pgx-compatible Postgres DSN.
PLATFORM_DATABASE_URL=postgres://postgres:postgres@localhost:5432/clario360?sslmode=disable

# Path to the PEM-encoded RSA public key used to verify gateway-minted RS256
# tokens. Generate a dev pair with `make keys`.
PLATFORM_JWT_PUBLIC_KEY_FILE=.keys/jwt-public.pem

# Optional issuer/audience enforcement (leave blank to skip).
PLATFORM_JWT_ISSUER=
PLATFORM_JWT_AUDIENCE=
